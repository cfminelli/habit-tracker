# Upstash Redis — required in production (Vercel)
# Add via: Vercel Dashboard → Integrations → Upstash Redis → Connect
# The integration sets these variables automatically.
UPSTASH_REDIS_REST_URL=https://<your-instance>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<your-token>

# In development these variables are NOT required.
# The app falls back to data/habits.json automatically when they are absent.
